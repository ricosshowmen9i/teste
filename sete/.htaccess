Options -Indexes
ServerSignature Off

# Bloqueia acesso a arquivos sensíveis
<FilesMatch "\.(db|sqlite|sqlite3|env|log|sh|bak|sql)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloqueia acesso direto à pasta db/
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redireciona todas as requisições para index.php exceto API e assets
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/sete/api/
    RewriteCond %{REQUEST_URI} !^/sete/assets/
    RewriteCond %{REQUEST_URI} !^/sete/uploads/avatars/
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>

# Cabeçalhos de segurança
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Compressão gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache para assets estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/gif  "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
